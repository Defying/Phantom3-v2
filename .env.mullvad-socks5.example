# Compose interpolation example for the container-only Mullvad SOCKS5 flow.
# Keep PHANTOM3_V2_ENV_FILE on a committed example file for static validation.
# When doing a supervised container run, point it at a real local .env instead.
PHANTOM3_V2_ENV_FILE=./.env.example
PHANTOM3_V2_MULLVAD_WIREGUARD_HOST_PATH=./runtime/mullvad/wireguard.conf
PHANTOM3_V2_POLYMARKET_PROXY_URL=socks5h://mullvad-socks5:1080
PHANTOM3_V2_POLYMARKET_OPERATOR_ELIGIBILITY=confirmed-eligible

WRAITH_HOST=0.0.0.0
WRAITH_PORT=4317
WRAITH_REMOTE_DASHBOARD=true
WRAITH_PUBLIC_BASE_URL=http://127.0.0.1:4317
WRAITH_DATA_DIR=./data
WRAITH_LOG_DIR=./logs
WRAITH_MARKET_REFRESH_MS=30000
WRAITH_MARKET_LIMIT=16
# simulation = no wallet/no live order gateway; paper = local ledger; live-disarmed = live control plane visible but disarmed.
WRAITH_RUNTIME_MODE=simulation
WRAITH_ENABLE_LIVE_MODE=false
WRAITH_ENABLE_LIVE_ARMING=false
WRAITH_LIVE_EXECUTION_ENABLED=false
WRAITH_LIVE_EXECUTION_VENUE=polymarket
WRAITH_LIVE_MAX_QUOTE_AGE_MS=5000
WRAITH_LIVE_MAX_RECONCILE_AGE_MS=15000
WRAITH_LIVE_MISSING_ORDER_GRACE_MS=30000
WRAITH_POLYMARKET_CLOB_HOST=https://clob.polymarket.com
WRAITH_POLYMARKET_CHAIN_ID=137
WRAITH_POLYMARKET_SIGNATURE_TYPE=0
WRAITH_POLYMARKET_USE_SERVER_TIME=true
# Keep false unless you intentionally want Wraith to derive/create Polymarket L2 API credentials from the signer.
WRAITH_POLYMARKET_ALLOW_API_KEY_DERIVATION=false
# Required for proxy/browser wallet signature types 1-3; leave empty for normal EOA signature type 0.
WRAITH_POLYMARKET_FUNDER_ADDRESS=
# Required for wallet-backed live gateway. Never commit a real private key.
WRAITH_POLYMARKET_PRIVATE_KEY=
# Supply all three L2 API credentials, or allow derivation above.
WRAITH_POLYMARKET_API_KEY=
WRAITH_POLYMARKET_API_SECRET=
WRAITH_POLYMARKET_API_PASSPHRASE=
WRAITH_CONTROL_TOKEN=replace_me_with_a_long_random_token

PHANTOM3_V2_HOST=0.0.0.0
PHANTOM3_V2_PORT=4317
PHANTOM3_V2_REMOTE_DASHBOARD=true
PHANTOM3_V2_PUBLIC_BASE_URL=http://127.0.0.1:4317
PHANTOM3_V2_DATA_DIR=./data
PHANTOM3_V2_LOG_DIR=./logs
PHANTOM3_V2_MARKET_REFRESH_MS=30000
PHANTOM3_V2_MARKET_LIMIT=16
# Optional: route only Polymarket outbound HTTP and future ws clients through a SOCKS proxy.
# Prefer socks5h:// for remote DNS when using a container-side proxy such as a Mullvad sidecar.
PHANTOM3_V2_POLYMARKET_PROXY_URL=
# unknown | confirmed-eligible | restricted
PHANTOM3_V2_POLYMARKET_OPERATOR_ELIGIBILITY=unknown
PHANTOM3_V2_CONTROL_TOKEN=replace_me_with_a_long_random_token

# Optional: container-only Mullvad WireGuard input for the compose sidecar path.
# Keep the actual .conf or vendor zip outside git, or under ./runtime/mullvad/ (ignored).
PHANTOM3_V2_MULLVAD_WIREGUARD_HOST_PATH=./runtime/mullvad/wireguard.conf
PHANTOM3_V2_MULLVAD_WIREGUARD_CONTAINER_PATH=/run/mullvad/wireguard.conf

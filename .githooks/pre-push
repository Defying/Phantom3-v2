#!/bin/zsh
set -u

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
script="$repo_root/scripts/notify-nate-after-push.sh"
[[ -x "$script" ]] || exit 0

remote_name="${1:-origin}"
refs_file=$(mktemp "${TMPDIR:-/tmp}/phantom3-v2-pre-push.XXXXXX") || exit 0

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -n "${local_ref:-}" ]] || continue
  print -r -- "$local_ref $local_sha $remote_ref $remote_sha" >> "$refs_file"
done

if [[ ! -s "$refs_file" ]]; then
  rm -f "$refs_file"
  exit 0
fi

/usr/bin/nohup "$script" "$PPID" "$remote_name" "$refs_file" >/dev/null 2>&1 &
disown 2>/dev/null || true
exit 0

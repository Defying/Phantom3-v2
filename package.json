{
  "name": "phantom3-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run check && npm run build:web",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch apps/api/src/index.ts",
    "start": "tsx apps/api/src/index.ts",
    "runtime:preflight": "./scripts/phantom3-runtime.sh preflight",
    "runtime:start": "./scripts/phantom3-runtime.sh start",
    "runtime:stop": "./scripts/phantom3-runtime.sh stop",
    "runtime:restart": "./scripts/phantom3-runtime.sh restart",
    "runtime:status": "./scripts/phantom3-runtime.sh status",
    "runtime:logs": "./scripts/phantom3-runtime.sh logs",
    "runtime:launchd:print": "./scripts/phantom3-runtime.sh launchd-print",
    "test:live-safety": "node --import tsx --test packages/paper-execution/src/live-safety.regression.test.ts",
    "verify:live-safety": "npm run check && npm run test:live-safety",
    "verify:mullvad-config-safety": "node scripts/verify-mullvad-config-safety.mjs",
    "verify:mullvad-socks5": "node scripts/verify-mullvad-socks5.mjs",
    "verify:paper-safe": "node scripts/verify-paper-safe.mjs",
    "verify:paper-runtime": "tsx scripts/verify-paper-runtime.ts",
    "verify:trading-preference": "tsx scripts/verify-trading-preference.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "axios": "^1.15.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socks-proxy-agent": "^10.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}

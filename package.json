{
  "name": "phantom3-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run check && npm run build:web",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch apps/api/src/index.ts",
    "start": "tsx apps/api/src/index.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}

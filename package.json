{
  "name": "wraith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run check && npm run build:web",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch apps/api/src/index.ts",
    "start": "tsx apps/api/src/index.ts",
    "test:live-safety": "node --import tsx --test packages/paper-execution/src/live-safety.regression.test.ts packages/live-execution/src/live-execution.regression.test.ts apps/api/src/runtime-store.live-controls.test.ts",
    "verify:live-safety": "npm run check && npm run test:live-safety",
    "verify:paper-safe": "node scripts/verify-paper-safe.mjs",
    "scan:updown": "tsx scripts/scan-updown-edge.ts",
    "watch:updown": "tsx scripts/watch-updown-candidates.ts",
    "observe:updown": "tsx scripts/record-updown-scan.ts",
    "evaluate:updown": "tsx scripts/evaluate-updown-observations.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@polymarket/clob-client-v2": "^1.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "viem": "^2.48.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
